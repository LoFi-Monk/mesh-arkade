{
  "name": "mesh-arkade",
  "version": "0.1.0",
  "description": "Museum-quality P2P application",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:core": "vitest run --config vitest.config.core.ts",
    "test:ui": "vitest",
    "dev:ui": "vite",
    "dev": "concurrently \"npm run dev:ui\" \"wait-on http://localhost:5173 && pear run --dev .\"",
    "build:ui": "vite build",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pear": {
    "name": "mesh-arkade",
    "pre": "pear-electron/pre",
    "gui": {
      "width": 1024,
      "height": 768,
      "backgroundColor": "#1a1a2e",
      "frame": true
    },
    "stage": {
      "ignore": [
        ".git/",
        ".agent/",
        ".opencode/",
        ".claude/",
        "src/",
        "tests/",
        "openspec/",
        "tsconfig.json",
        "vite.config.ts",
        "vitest.config.ts",
        "package-lock.json",
        "*.md"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-istanbul": "^2.1.8",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "shadcn": "^2.1.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "bare-fetch": "^2.7.0",
    "bare-fs": "^4.5.5",
    "bare-os": "^3.8.0",
    "bare-path": "^3.0.0",
    "bare-readline": "^1.2.2",
    "bittorrent-dht": "^11.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corestore": "^7.9.1",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.27.14",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "pear-bridge": "^1.2.5",
    "pear-electron": "^1.7.28",
    "random-access-memory": "^6.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx}": [
      "vitest related --run --passWithNoTests",
      "node scripts/check-tsdoc.mjs"
    ]
  }
}
